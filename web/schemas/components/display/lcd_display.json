{
  "id": "display.lcd_display",
  "domain": "display",
  "platform": "lcd_pcf8574",
  "platformByBus": {
    "i2c": "lcd_pcf8574",
    "gpio": "lcd_gpio"
  },
  "helpUrl": "https://esphome.io/components/display/lcd_display/",
  "display_builder": false,
  "requirements": [
    {
      "require": "bus:i2c",
      "when": {
        "key": "bus",
        "value": "i2c"
      }
    }
  ],
  "fields": [
    {
      "key": "id",
      "type": "id",
      "required": false,
      "lvl": "normal"
    },
    {
      "key": "bus",
      "type": "select",
      "required": true,
      "lvl": "simple",
      "default": "i2c",
      "options": [
        "i2c",
        "gpio"
      ]
    },
    {
      "key": "dimensions",
      "type": "text",
      "required": true,
      "lvl": "simple",
      "placeholder": "16x2"
    },
    {
      "key": "address",
      "type": "text",
      "required": false,
      "lvl": "simple",
      "default": "0x3F",
      "dependsOn": {
        "key": "bus",
        "value": "i2c"
      }
    },
    {
      "key": "i2c_id",
      "type": "id_ref",
      "required": false,
      "lvl": "normal",
      "domain": "i2c",
      "dependsOn": {
        "key": "bus",
        "value": "i2c"
      }
    },
    {
      "key": "data_pins",
      "type": "generated_list",
      "required": true,
      "lvl": "simple",
      "dependsOn": {
        "key": "bus",
        "value": "gpio"
      },
      "note": "ESPHome expects 4 or 8 GPIO pins for lcd_gpio.",
      "count": {
        "label": "Data pins",
        "type": "number",
        "required": true,
        "default": 4,
        "min": 4,
        "max": 8
      },
      "item": {
        "type": "gpio",
		"label": "GPIO",
        "required": false,
        "lvl": "simple",
        "placeholder": "GPIOXX"
      }
    },
    {
      "key": "enable_pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "placeholder": "GPIOXX",
      "dependsOn": {
        "key": "bus",
        "value": "gpio"
      }
    },
    {
      "key": "rs_pin",
      "type": "gpio",
      "required": true,
      "lvl": "simple",
      "placeholder": "GPIOXX",
      "dependsOn": {
        "key": "bus",
        "value": "gpio"
      }
    },
    {
      "key": "rw_pin",
      "type": "simple",
      "required": false,
      "lvl": "advanced",
      "placeholder": "GPIOXX",
      "dependsOn": {
        "key": "bus",
        "value": "gpio"
      }
    },
    {
      "key": "user_characters",
      "type": "yaml",
      "required": false,
      "lvl": "normal",
      "placeholder": "- position: 0\n  data: [0, 10, 21, 17, 10, 4, 0, 0]"
    },
    {
      "key": "lambda",
      "type": "lambda",
      "required": false,
      "lvl": "advanced"
    },
    {
      "key": "update_interval",
      "type": "duration",
      "required": false,
      "lvl": "normal",
      "default": "1s"
    },
    {
      "key": "custom_config",
      "type": "raw_yaml",
      "required": false,
      "lvl": "advanced"
    }
  ]
}
